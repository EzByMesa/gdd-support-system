# === GDD Служба поддержки — Переменные окружения ===

# JWT секрет (генерируется автоматически при первом запуске если не задан)
# JWT_SECRET=your-random-secret-here

# Порт бэкенда
PORT=3000

# Режим
NODE_ENV=production

# База данных (задаётся через Setup Wizard или здесь)
# SQLite:
# DATABASE_URL=./data/gdd.sqlite
# PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/gdd_support

# Раздавать фронтенд из backend (standalone без Nginx)
# SERVE_STATIC=true

# SMTP (опционально — для email-уведомлений)
# Настраивается через админку или здесь:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@example.com
